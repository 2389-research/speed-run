{
  "name": "@2389/speed-run-mcp",
  "version": "1.1.1",
  "description": "MCP server for hosted LLM code generation via Cerebras",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "speed-run-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/index.js",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/index.js --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.0.0"
  }
}
